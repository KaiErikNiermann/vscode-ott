{
    "name": "ott-workspace",
    "description": "Base workspace package",
    "version": "0.0.5",
    "type": "module",
    "private": true,
    "scripts": {
        "clean": "pnpm -r run clean",
        "watch": "tsc -b tsconfig.build.json --watch",
        "build": "tsc -b tsconfig.build.json && pnpm -r run build",
        "build:clean": "pnpm run clean && pnpm run build",
        "langium:generate": "pnpm --filter ott-language run langium:generate",
        "langium:watch": "pnpm --filter ott-language run langium:watch",
        "test": "pnpm --filter ott-language run test",
        "lint": "eslint --no-warn-ignored packages/*/src/**/*.ts",
        "lint:fix": "eslint --fix --no-warn-ignored packages/*/src/**/*.ts"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "~26.1.0",
        "eslint": "^10.6.0",
        "eslint-plugin-security": "^4.0.1",
        "eslint-plugin-sonarjs": "^4.1.0",
        "eslint-plugin-unicorn": "^71.0.0",
        "shx": "~0.4.0",
        "typescript": "~6.0.3",
        "typescript-eslint": "^8.62.0"
    },
    "volta": {
        "node": "22.20.0"
    },
    "packageManager": "pnpm@10.14.0",
    "bin": {
        "ott-language-server": "./bin/ott-language-server"
    }
}
